{
    "name": "bibrkacity/sanctum_session",
    "description": "Supporting work with variables related to Sanctum token",
    "keywords": ["laravel", "sanctum", "variables"],
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Bibrkacity\\SanctumSession\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Yuriy A. Maksymenko",
            "email": "bibrkacity@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^13.0 || ^12.1",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Bibrkacity\\SanctumSession\\SanctumSessionServiceProvider"
            ],
            "aliases": {
                "SanctumSession": "Bibrkacity\\SanctumSession\\Services\\SanctumSession"
            }
        }
    },
    "minimum-stability": "dev",
    "scripts": {
        "post-install-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postInstall",
            "@php artisan vendor:publish --provider=\"Bibrkacity\\SanctumSession\\SanctumSessionServiceProvider\"",
            "@php artisan migrate"
        ],
        "post-update-cmd": [
            "Illuminate\\Foundation\\ComposerScripts::postUpdate",
            "@php artisan vendor:publish --provider=\"Bibrkacity\\SanctumSession\\SanctumSessionServiceProvider\""
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
        ]
    }
}
